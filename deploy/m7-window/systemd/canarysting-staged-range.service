[Unit]
Description=CanarySting M7 staged-range engine (observe baseline + ground-truth labeler)
Documentation=https://github.com/henleda/canarysting
After=network-online.target
Wants=network-online.target

[Service]
# Runs as root: the OBSERVE-ONLY eBPF path loads + attaches cgroup_skb programs at
# the host cgroup-v2 root (CAP_BPF/CAP_NET_ADMIN/CAP_PERFMON). StateDirectory gives
# a durable /var/lib/canarysting for the bbolt baseline + event store that survives
# reboot (the >=2-week window).
EnvironmentFile=/etc/canarysting/m7.env
StateDirectory=canarysting
# $AGGRESSIVE_FLAG (no braces) word-splits: when unset/empty in m7.env it expands
# to NO argument, preserving the live window's posture exactly. The M9 demo toggle
# set-demo-posture.sh sets it to "-aggressive" (single-touch escalation) and back.
ExecStart=/opt/canarysting/bin/staged-range \
  -scope-boundary ${SCOPE} \
  -grpc-addr 127.0.0.1:50052 \
  -observe-cgroup /sys/fs/cgroup \
  -baseline-db ${BASELINE_DB} \
  -window-bucketer \
  -contain-inline \
  -ground-truth-registry ${GROUND_TRUTH} \
  -dashboard-tap-addr ${DASHBOARD_TAP_ADDR} \
  $AGGRESSIVE_FLAG \
  -i-am-running-a-staged-range
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
