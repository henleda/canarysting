# Copy to .env.local and adjust if the dashboard-backend is not on the default
# loopback address. Used by next.config.ts rewrites (server-side only — this is
# intentionally NOT a NEXT_PUBLIC_ var, so the backend address never ships to the
# browser).
#
# The dashboard-backend (cmd/dashboard-backend) defaults to 127.0.0.1:8089.
DASHBOARD_BACKEND_URL=http://127.0.0.1:8089

# Dev/verification-only visual fixture. Set to 1 to render the static prototype
# fixture (lib/fixture.ts) instead of live data. NEVER set this in production —
# the production render path is always useOverview().
# NEXT_PUBLIC_FIXTURE=1
