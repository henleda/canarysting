# Go
/bin/
*.test
*.out
# stray root-level cmd binaries (use `make bin` -> ./bin/ instead)
/engine
/canaryctl
/envoy-adapter
/envoy-selfcheck
/sting-selfcheck
/llm-attacker
/staged-range
/dashboard-backend
# M9: API keys must never be committed (D4)
*.key
# eBPF build artifacts
*.bpf.o
# editor / OS
.DS_Store
.idea/
.vscode/
# local agent tooling (not product code)
.claude-flow/
.swarm/
.claude/
# generated CO-RE kernel header (regenerate per kernel)
bpf/**/vmlinux.h

# Terraform working dirs / state / local vars (the .lock.hcl IS committed for reproducible providers)
**/.terraform/
*.tfstate
*.tfstate.*
**/terraform.tfvars

# M8 dashboard frontend (Next.js) — build/dependency/local-env artifacts
dashboard/app/node_modules/
dashboard/app/.next/
dashboard/app/.env.local
dashboard/app/next-env.d.ts
dashboard/app/tsconfig.tsbuildinfo

# Local scratch screenshots / Word docs (founder error reports)
*.docx
~$*.docx
